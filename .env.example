# ============================================================
# Delightree Prospecting Portal - environment configuration
# Copy to .env and fill in.  NEVER commit .env.
# ============================================================

# --- HubSpot (single private-app token; scoped per-rep in code by owner_id) ---
# Private app scopes needed (read-only for v1, we NEVER write back):
#   crm.objects.companies.read, crm.objects.contacts.read,
#   crm.objects.deals.read, crm.schemas.companies.read, crm.objects.owners.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Anthropic (Vinci drafting, step 4) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Latest, most capable model for drafting per playbook:
ANTHROPIC_MODEL=claude-opus-4-8

# --- Enrichment providers (step 3) ---
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=
ZOOMINFO_CLIENT_ID=
APOLLO_API_KEY=

# --- Google OAuth (step 6) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_HOSTED_DOMAIN=delightree.com
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Web session ---
SESSION_SECRET=change-me-to-a-long-random-string
# Shared passcode for the single team link (non-Google entry). Anyone with the link + code
# can select a rep and view that rep's book. Set a strong value before sharing; blank = no gate (local only).
TEAM_ACCESS_CODE=

# --- Paths / behavior ---
DATA_DIR=./data
REPS_FILE=./reps.json
# Optional: JSON file overriding HubSpot property internal names (see app/hubspot/properties.py)
HUBSPOT_PROPERTIES_FILE=

# Dedicated admin-board password (admins re-synced to this on every boot)
BOOTSTRAP_PASSWORD_ADMIN=
